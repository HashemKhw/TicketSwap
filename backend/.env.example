# Supabase: Project Settings → Database → Connection string (URI).
# For Prisma migrate/push, prefer the direct connection (port 5432), not pooler.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# JWT secret — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-secret-min-32-chars"

# Stripe test keys (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Public URL of this API (no trailing slash) — used for Stripe redirect URLs
API_PUBLIC_URL="http://localhost:4000"

# Comma-separated origins for CORS (Next.js dev + production)
CORS_ORIGINS="http://localhost:3000,https://your-app.vercel.app"
